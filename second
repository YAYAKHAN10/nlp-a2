def top_nn(word, emb, vocab, idx2w, n=10):
    """Top-n nearest neighbours by cosine similarity."""
    idx  = vocab.get(word, 0)
    vec  = emb[idx]
    nrm  = np.linalg.norm(vec) + 1e-10
    nrms = np.linalg.norm(emb, axis=1) + 1e-10
    sims = emb @ vec / (nrms * nrm)
    sims[idx] = -1
    top = np.argsort(sims)[::-1][:n]
    return [(idx2w.get(i, '?'), float(sims[i])) for i in top]

