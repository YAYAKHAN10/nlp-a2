import torch.nn as nn

class SkipGram(nn.Module):
    """Separate centre (V) and context (U) embedding matrices."""
    def __init__(self, vocab_size, embed_dim):
        super().__init__()
        self.V = nn.Embedding(vocab_size, embed_dim)   # centre
        self.U = nn.Embedding(vocab_size, embed_dim)   # context
        nn.init.uniform_(self.V.weight, -0.5 / embed_dim, 0.5 / embed_dim)
        nn.init.zeros_(self.U.weight)

    def forward(self, center, pos_ctx, neg_ctx):
        # center : (B,)   pos_ctx : (B,)   neg_ctx : (B, K)
        vc  = self.V(center)                                  # (B, D)
        uo  = self.U(pos_ctx)                                 # (B, D)
        un  = self.U(neg_ctx)                                 # (B, K, D)
        pos_score = (vc * uo).sum(dim=1)                      # (B,)
        neg_score = torch.bmm(un, vc.unsqueeze(2)).squeeze(2) # (B, K)
        # Binary cross-entropy loss (negative sampling objective)
        loss = (- torch.log(torch.sigmoid(pos_score)  + 1e-10).mean()
                - torch.log(torch.sigmoid(-neg_score) + 1e-10).mean())
        return loss

def train_skipgram(pairs, noise_p, vocab_size, dim=100, epochs=5, label=""):
    model = SkipGram(vocab_size, dim).to(DEVICE)
    opt   = optim.Adam(model.parameters(), lr=LR_W2V)
    loss_history = []
    n = len(pairs)
    spe = n // BATCH_W2V   # steps per epoch

    for ep in range(1, epochs + 1):
        idx = np.random.permutation(n)
        pr   = pairs[idx]
        ep_loss = 0.; steps = 0

        for s in range(0, n - BATCH_W2V, BATCH_W2V):
            bp   = pr[s : s + BATCH_W2V]
            ctr  = torch.tensor(bp[:, 0], dtype=torch.long, device=DEVICE)
            pos  = torch.tensor(bp[:, 1], dtype=torch.long, device=DEVICE)
            negs = torch.tensor(
                np.random.choice(vocab_size, size=(BATCH_W2V, K_NEG), p=noise_p),
                dtype=torch.long, device=DEVICE)

            opt.zero_grad()
            loss = model(ctr, pos, negs)
            loss.backward()
            opt.step()

            ep_loss += loss.item(); steps += 1
            if steps % max(1, spe // 5) == 0:
                print(f"  [{label}] Ep {ep}/{epochs}  step {steps}/{spe}  loss={ep_loss/steps:.4f}")

        avg = ep_loss / max(steps, 1)
        loss_history.append(avg)
        print(f"  [{label}] === Epoch {ep} done  avg_loss={avg:.4f} ===")

    V_mat = model.V.weight.data.cpu().numpy()
    U_mat = model.U.weight.data.cpu().numpy()
    avg_emb = 0.5 * (V_mat + U_mat)     # ½(V+U)
    return avg_emb, loss_history

