# ── Build skip-gram pairs (vectorised, fast) ──
def build_pairs(tokens, vocab, win):
    tids  = np.array([vocab.get(t, vocab.get('<UNK>', 0)) for t in tokens], dtype=np.int32)
    valid = np.where(tids != 0)[0]
    C_list, X_list = [], []
    for offset in range(-win, win + 1):
        if offset == 0: continue
        j_pos = valid + offset
        mask  = (j_pos >= 0) & (j_pos < len(tids))
        vp, xp = valid[mask], j_pos[mask]
        ok = tids[xp] != 0
        C_list.append(tids[vp[ok]])
        X_list.append(tids[xp[ok]])
    return np.column_stack([np.concatenate(C_list), np.concatenate(X_list)])

