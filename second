def mrr_score(emb, vocab, idx2w, pairs, n=10):
    rrs = []
    for q, t in pairs:
        if q not in vocab or t not in vocab:
            rrs.append(0.); continue
        nearest_neighbors_result = [w for w, _ in top_nn(q, emb, vocab, idx2w, n)] # Renamed 'nn'
        rrs.append(1. / (nearest_neighbors_result.index(t) + 1) if t in nearest_neighbors_result else 0.)
    return float(np.mean(rrs))

def mrr_ppmi(mat, pv, pi2w, pairs, n=10):
    rrs = []
    for q, t in pairs:
        if q not in pv or t not in pv:
            rrs.append(0.); continue
        qi = pv[q]; vec = mat[qi]
        nrms = np.linalg.norm(mat, axis=1) + 1e-10
        sims = mat @ vec / (nrms * (np.linalg.norm(vec) + 1e-10)); sims[qi] = -1
        top10 = [pi2w[i] for i in np.argsort(sims)[::-1][:n]]
        rrs.append(1. / (top10.index(t) + 1) if t in top10 else 0.)
    return float(np.mean(rrs))

