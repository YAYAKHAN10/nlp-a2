# Morphological suffix rules (Urdu)
VERB_SUFFIXES  = ('ئ','گ','یں','یا','ئے','تا','تی','تے','نا','نی','نے','کر','اً','ہو')
NOUN_SUFFIXES  = ('ت','ار','وں','یوں','اں','یاں','گاہ','دان','ستان','خانہ')
ADJ_SUFFIXES   = ('ول','ند','ین','انہ','آور','مند','پرست')

def rule_pos(tok, prev=None, next_tok=None):
    if tok in LEXICON:
        return LEXICON[tok]
    if tok == '<NUM>' or tok.isdigit():
        return 'NUM'
    if all(c in '،؟!.:;()[]۔؛' for c in tok):
        return 'PUNC'
    if tok.endswith(VERB_SUFFIXES):
        return 'VERB'
    if tok.endswith(NOUN_SUFFIXES):
        return 'NOUN'
    if tok.endswith(ADJ_SUFFIXES):
        return 'ADJ'
    if prev in POSTP or tok in ('سے','کو','پر','میں'):
        return 'NOUN'
    return 'UNK'

def pos_tag(tokens):
    tags = []
    for i, tok in enumerate(tokens):
        prev = tokens[i-1] if i > 0 else None
        nxt  = tokens[i+1] if i < len(tokens)-1 else None
        tags.append(rule_pos(tok, prev, nxt))
    return tags

