def ner_tag_sentence(tokens):
    tags = ['O'] * len(tokens)
    i = 0
    while i < len(tokens):
        tok = tokens[i]
        # Check multi-word entities first
        if i + 1 < len(tokens):
            bigram = tok + ' ' + tokens[i+1]
            if bigram in GAZETTEER_LOC:
                tags[i] = 'B-LOC'; tags[i+1] = 'I-LOC'; i += 2; continue
            if bigram in GAZETTEER_ORG:
                tags[i] = 'B-ORG'; tags[i+1] = 'I-ORG'; i += 2; continue
        # Single token
        if tok in GAZETTEER_PER:
            tags[i] = 'B-PER'
        elif tok in GAZETTEER_LOC:
            tags[i] = 'B-LOC'
        elif tok in GAZETTEER_ORG:
            tags[i] = 'B-ORG'
        elif tok in GAZETTEER_MISC:
            tags[i] = 'B-MISC'
        else:
            # heuristic: capitalised or ALL-CAPS sub-tokens
            if len(tok) >= 3 and tok not in ('کے','کی','کا','نے','سے','کو','پر','میں','اور','یا'):
                prev_tag = tags[i-1] if i > 0 else 'O'
                if prev_tag.startswith('B-PER') or prev_tag.startswith('I-PER'):
                    tags[i] = 'I-PER'
        i += 1
    return tags

