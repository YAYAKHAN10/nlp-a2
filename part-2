# ── Extract sentences from docs ──
def extract_sentences(docs, doc_topics, min_len=3, max_len=50):
    sents = []   # (tokens_list, topic)
    print(f"DEBUG: Number of documents received by extract_sentences: {len(docs)}")
    if not docs:
        print("DEBUG: Docs list is empty, returning empty sentences list.")
        return []

    for doc_idx, (doc, topic) in enumerate(zip(docs, doc_topics)):
        all_doc_tokens = doc.split()

        # Debugging output for the first few documents
        if doc_idx < 5:
            print(f"DEBUG: Doc {doc_idx} (topic: {topic}) - Raw char length: {len(doc)}, Token count after split(): {len(all_doc_tokens)}")
            if not all_doc_tokens:
                print(f"DEBUG: Doc {doc_idx} resulted in 0 tokens after split(). Content sample: '{doc[:100]}'")
            elif len(all_doc_tokens) < min_len:
                print(f"DEBUG: Doc {doc_idx} token count ({len(all_doc_tokens)}) is less than min_len ({min_len}). Content sample: '{' '.join(all_doc_tokens[:min_len+2])}'")

        if not all_doc_tokens:
            continue # Skip documents that yield no tokens

        # Split into chunks of max_len
        for i in range(0, len(all_doc_tokens), max_len):
            chunk = all_doc_tokens[i : i + max_len]
            if len(chunk) >= min_len: # Ensure chunk is at least min_len
                sents.append((chunk, topic))
            # else:
            #     if doc_idx < 5 and len(chunk) > 0: # Only print if chunk is not empty and too short
            #         print(f"DEBUG: Doc {doc_idx} chunk length ({len(chunk)}) is less than min_len ({min_len}). Chunk content: '{' '.join(chunk)}'")

    print(f"DEBUG: Total sents collected before final sampling: {len(sents)}")
    return sents

