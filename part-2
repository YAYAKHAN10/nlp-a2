# ──────────────────────────────────────────────────────────────────
# CRF LAYER with Viterbi decoding (from scratch)
# ──────────────────────────────────────────────────────────────────
class CRF(nn.Module):
    def __init__(self, num_tags):
        super().__init__()
        self.num_tags   = num_tags
        self.transitions = nn.Parameter(torch.randn(num_tags, num_tags) * 0.1)
        # Penalise impossible start/end states
        self.start_trans = nn.Parameter(torch.randn(num_tags) * 0.1)
        self.end_trans   = nn.Parameter(torch.randn(num_tags) * 0.1)

    def _log_likelihood(self, emissions, tags, mask):
        # emissions: (B, T, C)   tags: (B, T)   mask: (B, T) bool
        B, T, C = emissions.shape
        score = torch.zeros(B, device=emissions.device)
        score += self.start_trans[tags[:, 0]]
        for t in range(T):
            em_score  = emissions[:, t, :].gather(1, tags[:, t].unsqueeze(1)).squeeze(1)
            score    += em_score * mask[:, t]
            if t < T - 1:
                trans_score = self.transitions[tags[:, t], tags[:, t+1]]
                score      += trans_score * mask[:, t+1]
        last_tag = tags.gather(1, mask.long().sum(1, keepdim=True) - 1).squeeze(1)
        score   += self.end_trans[last_tag]
        return score

    def _log_partition(self, emissions, mask):
        B, T, C = emissions.shape
        alpha = self.start_trans.unsqueeze(0) + emissions[:, 0, :]
        for t in range(1, T):
            emit   = emissions[:, t, :].unsqueeze(1)
            trans  = self.transitions.unsqueeze(0)
            scores = alpha.unsqueeze(2) + emit + trans
            alpha_new = torch.logsumexp(scores, dim=1)
            alpha = torch.where(mask[:, t].unsqueeze(1), alpha_new, alpha)
        alpha += self.end_trans.unsqueeze(0)
        return torch.logsumexp(alpha, dim=1)

    def forward(self, emissions, tags, mask):
        ll   = self._log_likelihood(emissions, tags, mask)
        logZ = self._log_partition(emissions, mask)
        return (logZ - ll).mean()

    def viterbi(self, emissions, mask):
        B, T, C = emissions.shape
        viterbi_score = self.start_trans.unsqueeze(0) + emissions[:, 0, :]
        backpointers  = []
        for t in range(1, T):
            em    = emissions[:, t, :].unsqueeze(1)
            tr    = self.transitions.unsqueeze(0)
            score = viterbi_score.unsqueeze(2) + tr + em
            best_score, best_tag = score.max(dim=1)
            backpointers.append(best_tag)
            viterbi_score = torch.where(mask[:, t].unsqueeze(1), best_score, viterbi_score)
        viterbi_score += self.end_trans.unsqueeze(0)
        best_last      = viterbi_score.argmax(dim=1)
        best_paths     = [best_last.unsqueeze(1)]
        for bp in reversed(backpointers):
            best_last = bp.gather(1, best_last.unsqueeze(1)).squeeze(1)
            best_paths.insert(0, best_last.unsqueeze(1))
        return torch.cat(best_paths, dim=1)

print("CRF class defined.")



# ──────────────────────────────────────────────────────────────────
# 2-LAYER BIDIRECTIONAL LSTM SEQUENCE LABELER
# ──────────────────────────────────────────────────────────────────
class BiLSTMTagger(nn.Module):
    def __init__(self, vocab_size, embed_dim, hidden_dim, num_tags,
                 pretrained_emb=None, freeze_emb=False,
                 dropout=0.5, use_crf=False, num_layers=2, bidirectional=True):
        super().__init__()
        self.use_crf       = use_crf
        self.bidirectional = bidirectional

        # Embedding
        self.embed = nn.Embedding(vocab_size, embed_dim, padding_idx=0)
        if pretrained_emb is not None:
            self.embed.weight = nn.Parameter(
                torch.tensor(pretrained_emb, dtype=torch.float))
        self.embed.weight.requires_grad = not freeze_emb

        # LSTM
        self.lstm = nn.LSTM(
            embed_dim, hidden_dim,
            num_layers=num_layers,
            batch_first=True,
            bidirectional=bidirectional,
            dropout=dropout if num_layers > 1 else 0.0
        )
        self.dropout = nn.Dropout(dropout)

        lstm_out_dim = hidden_dim * (2 if bidirectional else 1)
        self.fc      = nn.Linear(lstm_out_dim, num_tags)

        self.crf = CRF(num_tags) if use_crf else None

    def forward(self, x, lengths, tags=None):
        emb  = self.dropout(self.embed(x))          # (B, T, E)
        packed = nn.utils.rnn.pack_padded_sequence(
            emb, lengths.cpu(), batch_first=True, enforce_sorted=False)
        out, _ = self.lstm(packed)
        out, _ = nn.utils.rnn.pad_packed_sequence(out, batch_first=True)
        out    = self.dropout(out)
        emissions = self.fc(out)                     # (B, T, C)

        if self.use_crf and tags is not None:
            mask = (x != 0)
            loss = self.crf(emissions, tags, mask)
            return loss
        elif self.use_crf:
            mask = (x != 0)
            return self.crf.viterbi(emissions, mask)
        else:
            return emissions

print("BiLSTMTagger class defined.")



def train_bilstm(model, train_loader, val_loader, idx2tag, task="pos",
                 epochs=20, patience=5, label=""):
    opt = optim.Adam(model.parameters(), lr=1e-3, weight_decay=1e-4)
    criterion = nn.CrossEntropyLoss(ignore_index=-1)
    best_f1, wait = 0.0, 0
    train_losses, val_losses = [], []

    for epoch in range(1, epochs + 1):
        # ── Train ──
        model.train(); ep_loss = 0.; steps = 0
        for x, y, lengths in train_loader:
            x, y, lengths = x.to(DEVICE), y.to(DEVICE), lengths.to(DEVICE)
            opt.zero_grad()
            if model.use_crf:
                mask = (x != 0)
                valid_y = y.clone(); valid_y[y == -1] = 0
                loss = model(x, lengths, valid_y)
            else:
                logits = model(x, lengths)
                B, T, C = logits.shape
                loss = criterion(logits.view(B*T, C), y.view(B*T))
            loss.backward(); opt.step()
            ep_loss += loss.item(); steps += 1

        avg_tr = ep_loss / max(steps, 1)
        train_losses.append(avg_tr)

        # ── Validate ──
        model.eval(); vl_loss = 0.; vsteps = 0
        all_preds, all_gold = [], []
        with torch.no_grad():
            for x, y, lengths in val_loader:
                x, y, lengths = x.to(DEVICE), y.to(DEVICE), lengths.to(DEVICE)
                if model.use_crf:
                    mask    = (x != 0)
                    valid_y = y.clone(); valid_y[y == -1] = 0
                    vl_loss += model(x, lengths, valid_y).item(); vsteps += 1
                    preds   = model(x, lengths)
                else:
                    logits  = model(x, lengths)
                    B, T, C = logits.shape
                    vl_loss += criterion(logits.view(B*T, C), y.view(B*T)).item(); vsteps += 1
                    preds   = logits.argmax(dim=-1)

                # Collect predictions (non-padded)
                mask_cpu = (y != -1).cpu().numpy()
                for b in range(x.size(0)):
                    L = int(lengths[b])
                    all_preds.extend(preds[b, :L].cpu().numpy().tolist())
                    all_gold.extend(y[b, :L].cpu().numpy().tolist())

        avg_vl = vl_loss / max(vsteps, 1)
        val_losses.append(avg_vl)
        f1 = f1_score(all_gold, all_preds, average='macro',
                      labels=list(range(len(idx2tag))), zero_division=0)

        print(f"  [{label}] Epoch {epoch:2d}/{epochs}  "
              f"train_loss={avg_tr:.4f}  val_loss={avg_vl:.4f}  val_F1={f1:.4f}")

        if f1 > best_f1:
            best_f1 = f1; wait = 0
            torch.save(model.state_dict(), f"{MODEL_DIR}/best_{label}.pt")
        else:
            wait += 1
            if wait >= patience:
                print(f"  Early stopping at epoch {epoch}")
                break

    # Restore best
    model.load_state_dict(torch.load(f"{MODEL_DIR}/best_{label}.pt", map_location=DEVICE))
    return train_losses, val_losses, best_f1

