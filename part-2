def encode_sent(tokens, vocab, max_len=None):
    ids = [vocab.get(t, vocab['<UNK>']) for t in tokens]
    if max_len:
        ids = ids[:max_len]
    return ids

def encode_tags(tags, tag2idx):
    return [tag2idx.get(t, 0) for t in tags]

# ── Dataset ──
class SeqDataset(Dataset):
    def __init__(self, tokens_list, tags_list, tok_vocab, tag2idx):
        self.data = []
        for tokens, tags in zip(tokens_list, tags_list):
            x = encode_sent(tokens, tok_vocab)
            y = encode_tags(tags,   tag2idx)
            self.data.append((x, y))

    def __len__(self): return len(self.data)
    def __getitem__(self, i): return self.data[i]

def collate_fn(batch):
    xs, ys   = zip(*batch)
    lengths  = [len(x) for x in xs]
    max_len  = max(lengths)
    xs_pad   = torch.zeros(len(xs), max_len, dtype=torch.long)
    ys_pad   = torch.full((len(ys), max_len), -1, dtype=torch.long)  # -1 = ignore
    for i, (x, y) in enumerate(zip(xs, ys)):
        xs_pad[i, :len(x)] = torch.tensor(x, dtype=torch.long)
        ys_pad[i, :len(y)] = torch.tensor(y, dtype=torch.long)
    return xs_pad, ys_pad, torch.tensor(lengths)

