def load_corpus(path, encoding='utf-8', errors=None):
    """Returns list of article strings."""
    with open(path, encoding=encoding, errors=errors) as f:
        raw = f.read()
    docs = []
    for block in raw.split('ARTICLE_'):
        block = block.strip()
        if not block:
            continue
        lines = block.split('\n')
        text_lines = [l.strip() for l in lines[1:] if l.strip()]
        if text_lines:
            docs.append(' '.join(text_lines))
    return docs

def load_all_tokens(path, encoding='utf-8', errors=None):
    with open(path, encoding=encoding, errors=errors) as f:
        raw = f.read()
    tokens = []
    for line in raw.split('\n'):
        line = line.strip()
        if line and not line.startswith('ARTICLE_'):
            tokens.extend(line.split())
    return tokens

