WINDOW_K  = 5
PPMI_SIZE = 2000   # top-2000 words for PPMI matrix

common_words = [w for w, _ in global_counter.most_common(PPMI_SIZE)]
ppmi_vocab   = {w: i for i, w in enumerate(common_words)}
ppmi_idx2w   = {i: w for w, i in ppmi_vocab.items()}

# Word counts for probability estimates
word_cnt     = Counter(tokens_clean)
total_tokens = sum(word_cnt.values())

# Co-occurrence counts (vectorised over offsets)
tids_clean = np.array([vocab.get(t, vocab['<UNK>']) for t in tokens_clean], dtype=np.int32)
ppmi_ids   = np.array([ppmi_vocab.get(t, -1)        for t in tokens_clean], dtype=np.int32)

cooc_counts = np.zeros((PPMI_SIZE, PPMI_SIZE), dtype=np.float32)
total_pairs = 0

for offset in range(-WINDOW_K, WINDOW_K + 1):
    if offset == 0:
        continue
    i_pos = np.arange(len(ppmi_ids))
    j_pos = i_pos + offset
    mask  = (j_pos >= 0) & (j_pos < len(ppmi_ids))
    ip, jp = ppmi_ids[i_pos[mask]], ppmi_ids[j_pos[mask]]
    valid  = (ip >= 0) & (jp >= 0)
    ip, jp = ip[valid], jp[valid]
    np.add.at(cooc_counts, (ip, jp), 1)
    total_pairs += len(ip)

print(f"Total co-occurrence pairs: {total_pairs}")

# P(w1, w2), P(w1), P(w2)
p_joint = cooc_counts / (total_pairs + 1e-10)
p_w     = np.array([word_cnt.get(w, 0) / total_tokens for w in common_words], dtype=np.float32)

# PPMI(w1,w2) = max(0, log2(P(w1,w2) / P(w1)*P(w2)))
outer   = np.outer(p_w, p_w) + 1e-10
ppmi_matrix = np.maximum(0.0, np.log2(p_joint / outer + 1e-10))
np.fill_diagonal(ppmi_matrix, 0)

np.save(f"{EMBED_DIR}/ppmi_matrix.npy", ppmi_matrix)
print(f"PPMI matrix saved  shape={ppmi_matrix.shape}")

# ── Top-5 nearest neighbours (cosine) for 10 query words ──
def ppmi_neighbors(word, n=5):
    if word not in ppmi_vocab:
        return []
    qi  = ppmi_vocab[word]
    vec = ppmi_matrix[qi]
    norms = np.linalg.norm(ppmi_matrix, axis=1) + 1e-10
    sims  = ppmi_matrix @ vec / (norms * (np.linalg.norm(vec) + 1e-10))
    sims[qi] = -1
    top = np.argsort(sims)[::-1][:n]
    return [(ppmi_idx2w[i], float(sims[i])) for i in top]

